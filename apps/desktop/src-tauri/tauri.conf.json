{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "NanoPaste",
  "version": "0.1.0",
  "identifier": "com.nanopaste.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev:web",
    "beforeBuildCommand": "npm run build:web"
  },
  "app": {
    "windows": [
      {
        "title": "NanoPaste",
        "width": 1000,
        "height": 700,
        "minWidth": 780,
        "minHeight": 560,
        "resizable": true,
        "fullscreen": false,
        "additionalBrowserArgs": "--disable-gpu --disable-features=msWebOOUI,msPdfOOUI,msSmartScreenProtection"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
